{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^VERSION$/"],
      "matchStrings": [
        "(?<currentValue>[0-9.]+)"
      ],
      "depNameTemplate": "ollama/ollama",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    }
  ],
  "baseBranchPatterns": [
    "cpu",
    "latest",
    "rocm",
    "vulkan"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["ollama/ollama"],
      "matchBaseBranches": ["cpu", "latest", "rocm", "vulkan"]
    }
  ]
}
